<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="app.controller.vendedor.ConfigPortasController"
      spacing="15"
      alignment="CENTER"
      prefWidth="520"
      prefHeight="500">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Configuração de Portas"
           style="-fx-font-size:18px; -fx-font-weight:bold;"/>

    <!-- CAMPOS DE CONFIGURAÇÃO -->

    <GridPane hgap="10" vgap="10" alignment="CENTER">

        <Label text="Tipo da Porta" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <ComboBox fx:id="cbTipo"
                  GridPane.rowIndex="0"
                  GridPane.columnIndex="1"/>

        <Label text="Batente" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <ComboBox fx:id="cbBatente"
                  GridPane.rowIndex="1"
                  GridPane.columnIndex="1"/>

        <Label text="Aplicação" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <ComboBox fx:id="cbAplicacao"
                  GridPane.rowIndex="2"
                  GridPane.columnIndex="1"/>

        <Label text="Abertura" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <ComboBox fx:id="cbAbertura"
                  GridPane.rowIndex="3"
                  GridPane.columnIndex="1"/>

        <Label text="Tamanho" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <ComboBox fx:id="cbTamanho"
                  GridPane.rowIndex="4"
                  GridPane.columnIndex="1"/>

    </GridPane>

    <!-- BOTÃO ADICIONAR -->

    <Button text="Adicionar Porta"
            onAction="#adicionarPorta"/>

    <!-- TABELA -->

    <TableView fx:id="tablePortas" prefHeight="220">

        <columns>

            <TableColumn fx:id="colTipo"
                         text="Tipo"
                         prefWidth="140"/>

            <TableColumn fx:id="colBatente"
                         text="Batente"
                         prefWidth="80"/>

            <TableColumn fx:id="colAbertura"
                         text="Abertura"
                         prefWidth="120"/>

            <TableColumn fx:id="colTamanho"
                         text="Tamanho"
                         prefWidth="140"/>

        </columns>

    </TableView>

    <!-- BOTÕES INFERIORES -->

    <HBox spacing="10" alignment="CENTER">

        <Button text="Remover Porta"
                onAction="#removerPorta"/>

        <Button text="Salvar"
                onAction="#salvar"/>

    </HBox>

</VBox>