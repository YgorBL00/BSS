<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="app.controller.vendedor.CalculoPainelUsuario"
            prefHeight="750.0" prefWidth="1150.0"
            style="-fx-background-color: linear-gradient(from 0% 100% to 0% 0%, #b3e0ff, white);">

    <VBox alignment="CENTER"
          spacing="12"
          AnchorPane.topAnchor="0.0"
          AnchorPane.bottomAnchor="0.0"
          AnchorPane.leftAnchor="0.0"
          AnchorPane.rightAnchor="0.0">

        <!-- CARD -->
        <VBox alignment="CENTER"
              spacing="15"
              maxWidth="320"
              style="-fx-background-color: white;
                     -fx-background-radius: 12;
                     -fx-padding: 35;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 15, 0, 0, 5);">

            <Label text="CÁLCULO DE PAINÉIS"
                   style="-fx-font-size: 22; -fx-text-fill: #23336f;"/>

            <Label text="Funcionalidade em desenvolvimento"
                   style="-fx-font-size: 15; -fx-text-fill: #555;"
                   wrapText="true"/>

            <Button fx:id="btnVoltar"
                    text="Voltar"
                    prefWidth="160"
                    onAction="#voltarPainel"
                    style="-fx-background-color: #245edb;
                           -fx-text-fill: white;
                           -fx-background-radius: 24;
                           -fx-font-size: 14;"/>

        </VBox>

    </VBox>

</AnchorPane>